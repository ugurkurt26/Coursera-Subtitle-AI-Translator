{
  "manifest_version": 3,
  "name": "Coursera Subtitle AI Translator",
  "version": "3.0.0",
  "description": "AI subtitle translation extension powered by Gemini",
  "content_scripts": [
    {
      "matches": [
        "*://www.coursera.org/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Coursera Subtitle AI Translator",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ]
}
